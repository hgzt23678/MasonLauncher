{
  "name": "mason-launcher",
  "productName": "Mason Launcher",
  "version": "1.4.1",
  "description": "A clean instance launcher for Minecraft using Microsoft authentication and official Mojang metadata.",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "verify:minecraft": "node scripts/run-minecraft-verification.cjs",
    "check": "npm run typecheck && npm run lint && npm run test",
    "build": "npm run check && npm run make",
    "build:package": "npm run check && npm run package"
  },
  "keywords": [],
  "author": "hgzt23678",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "8.0.0-alpha.9",
    "@electron-forge/maker-deb": "8.0.0-alpha.9",
    "@electron-forge/maker-rpm": "8.0.0-alpha.9",
    "@electron-forge/maker-squirrel": "8.0.0-alpha.9",
    "@electron-forge/maker-zip": "8.0.0-alpha.9",
    "@electron-forge/plugin-auto-unpack-natives": "8.0.0-alpha.9",
    "@electron-forge/plugin-fuses": "8.0.0-alpha.9",
    "@electron-forge/plugin-vite": "8.0.0-alpha.9",
    "@electron/fuses": "2.1.2",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/yazl": "^3.3.1",
    "@typescript-eslint/eslint-plugin": "8.46.4",
    "@typescript-eslint/parser": "8.46.4",
    "electron": "42.4.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "2.7.1",
    "eslint-plugin-import": "^2.32.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "yazl": "^3.3.1"
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.3",
    "@material/web": "^2.4.1",
    "@xmcl/core": "^2.15.1",
    "@xmcl/installer": "^6.1.2",
    "@xmcl/task": "^4.1.1",
    "@xmcl/unzip": "^2.1.2",
    "electron-squirrel-startup": "^1.0.1",
    "fast-xml-parser": "^5.8.0",
    "undici": "7.27.2"
  },
  "overrides": {
    "undici": "7.27.2"
  }
}
